# ── Desarrollo local (Docker) ──────────────────────────────────────
# cp .env.example .env.local
DATABASE_URL=postgresql://redayuda:redayuda@localhost:5432/redayuda

NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Producción (Supabase + Vercel) ─────────────────────────────────
# La integración Supabase inyecta POSTGRES_URL (pooler, puerto 6543). No hace falta DATABASE_URL.
# Si defines DATABASE_URL manualmente, usa el pooler — NO db.[ref].supabase.co (IPv6, falla en Vercel):
# DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
NEXT_PUBLIC_APP_URL=https://red-ayudas.vercel.app
