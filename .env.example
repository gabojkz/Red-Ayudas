# ── Desarrollo local (Docker) ──────────────────────────────────────
# cp .env.example .env.local
DATABASE_URL=postgresql://redayuda:redayuda@localhost:5432/redayuda

NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Producción (Supabase + Vercel) ─────────────────────────────────
# La integración Supabase inyecta POSTGRES_URL en Vercel (la app la usa automáticamente).
# O define manualmente:
# DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@....pooler.supabase.com:6543/postgres?sslmode=require
NEXT_PUBLIC_APP_URL=https://red-ayudas.vercel.app
